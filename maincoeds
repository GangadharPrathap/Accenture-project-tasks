WITH LATEST_PERFORMANCE AS
(
    SELECT fp.*
    FROM FACT_PERFORMANCE fp
    JOIN
    (
        SELECT
            EMP_SK,
            MAX(DAY_SK) MAX_DAY
        FROM FACT_PERFORMANCE
        GROUP BY EMP_SK
    ) x
    ON fp.EMP_SK=x.EMP_SK
    AND fp.DAY_SK=x.MAX_DAY
)

SELECT
    lp.RATING_SCORE,

    CASE
        WHEN fa.EMP_SK IS NULL
            THEN 'Stayed'
        ELSE 'Exited'
    END EMPLOYEE_STATUS,

    COUNT(*) EMPLOYEE_COUNT

FROM LATEST_PERFORMANCE lp

LEFT JOIN FACT_ATTRITION fa
ON lp.EMP_SK=fa.EMP_SK

GROUP BY
    lp.RATING_SCORE,
    CASE
        WHEN fa.EMP_SK IS NULL
            THEN 'Stayed'
        ELSE 'Exited'
    END

ORDER BY
    lp.RATING_SCORE;
