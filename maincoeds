SELECT
    fp.RATING_SCORE,
    CASE
        WHEN fa.EMP_SK IS NULL THEN 'Stayed'
        ELSE 'Exited'
    END AS EMPLOYEE_STATUS,
    COUNT(DISTINCT fp.EMP_SK) AS EMPLOYEE_COUNT
FROM FACT_PERFORMANCE fp
LEFT JOIN FACT_ATTRITION fa
    ON fp.EMP_SK = fa.EMP_SK
GROUP BY
    fp.RATING_SCORE,
    CASE
        WHEN fa.EMP_SK IS NULL THEN 'Stayed'
        ELSE 'Exited'
    END
ORDER BY fp.RATING_SCORE, EMPLOYEE_STATUS;
