SELECT
    d.DEPARTMENT_NAME,
    ROUND(
        COUNT(DISTINCT fa.EMP_SK)*100.0/
        COUNT(DISTINCT fp.EMP_SK),2
    ) AS ATTRITION_RATE
FROM FACT_PERFORMANCE fp
JOIN DIM_DEPARTMENT d
ON fp.DEPT_SK=d.DEPT_SK

LEFT JOIN FACT_ATTRITION fa
ON fp.EMP_SK=fa.EMP_SK

GROUP BY d.DEPARTMENT_NAME;

