# Bonus Views (Recommended for OAC Dashboard)

## Attrition by Department

```sql
CREATE OR REPLACE VIEW VW_DEPARTMENT_ATTRITION AS
SELECT
    d.DEPARTMENT_NAME,
    COUNT(*) AS ATTRITIONS
FROM FACT_ATTRITION fa
JOIN DIM_DEPARTMENT d
ON fa.DEPT_SK=d.DEPT_SK
GROUP BY d.DEPARTMENT_NAME;
```

---

## Average KPI by Department

```sql
CREATE OR REPLACE VIEW VW_DEPARTMENT_KPI AS
SELECT
    d.DEPARTMENT_NAME,
    ROUND(AVG(fp.KPI_ACHIEVEMENT_PERCENTAGE),2) AVG_KPI
FROM FACT_PERFORMANCE fp
JOIN DIM_DEPARTMENT d
ON fp.DEPT_SK=d.DEPT_SK
GROUP BY d.DEPARTMENT_NAME;
```

---

## Performance Rating Distribution

```sql
CREATE OR REPLACE VIEW VW_PERFORMANCE_DISTRIBUTION AS
SELECT
    RATING_SCORE,
    COUNT(*) TOTAL_EMPLOYEES
FROM FACT_PERFORMANCE
GROUP BY RATING_SCORE;
```

---

## Attrition Type Distribution

```sql
CREATE OR REPLACE VIEW VW_ATTRITION_TYPE AS
SELECT
    EXIT_REASON_CATEGORY,
    COUNT(*) TOTAL_EMPLOYEES
FROM FACT_ATTRITION
GROUP BY EXIT_REASON_CATEGORY;
```

